# VibeCall Backend — copy to .env and fill in values

# Database (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/vibecall

# Auth
JWT_SECRET=your-secret-minimum-32-characters-long-random-string

# LiveKit Cloud — livekit.io → Settings → Keys
LIVEKIT_API_KEY=APIpYn9E7HHDhwA
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_HOST=wss://vibecall-xizkbpz8.livekit.cloud

# Anthropic (Claude) — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Resend (email) — resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# Adapty.io — app.adapty.io → Settings → API Keys
ADAPTY_SECRET_KEY=your_adapty_server_side_secret
ADAPTY_WEBHOOK_SECRET=your_adapty_webhook_signing_secret

# CORS — your Vercel frontend URL
CLIENT_URL=https://vibecall.vercel.app

# Server
PORT=4000
NODE_ENV=production
