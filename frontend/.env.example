# VibeCall Frontend — copy to .env.local and fill in values

# Your Railway backend URL (no trailing slash)
VITE_API_URL=https://your-app.up.railway.app

# Deepgram API key — console.deepgram.com (safe for browser)
VITE_DEEPGRAM_KEY=your_deepgram_api_key_here

# Adapty web paywall URL — app.adapty.io → Paywalls → Web
VITE_ADAPTY_PAYWALL_URL=https://pay.adapty.io/your-paywall-id

# Adapty public SDK key
VITE_ADAPTY_PUBLIC_KEY=public_live_your_key_here
